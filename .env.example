# =====================================================
# T-KAI Shop — Variables d'environnement
# =====================================================

# --- Base de données PostgreSQL ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/tkai_shop?schema=public"

# --- Admin bootstrap (utilisé UNE SEULE FOIS pour créer l'AdminUser en DB) ---
# Au premier login, ce mot de passe est hashé (bcrypt) puis stocké en base.
ADMIN_PSEUDO="admin"
ADMIN_PASSWORD="change-me-strong-password"

# --- Secret de signature du cookie de session admin (HMAC-SHA256) ---
# Génère une chaîne aléatoire (min 32 caractères).
# PowerShell : [Convert]::ToBase64String((1..48 | % { Get-Random -Max 256 }))
ADMIN_SESSION_SECRET="change-me-with-a-long-random-string-min-32-chars"

# --- Email destinataire admin (reçoit les commandes par mail) ---
ADMIN_EMAIL="admin@t-kai.com"

# =====================================================
# SMTP — envoi des emails (commande client + admin)
# =====================================================
# Gmail recommandé avec un "App password" (2FA activée + App password créé).
#   1. https://myaccount.google.com/security  -> active la 2FA
#   2. https://myaccount.google.com/apppasswords  -> crée un App password
#   3. Colle l'App password (16 caractères) dans SMTP_PASSWORD
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="ton.email@gmail.com"
SMTP_PASSWORD="xxxx xxxx xxxx xxxx"
SMTP_FROM="T-KAI Shop <no-reply@t-kai.com>"

# =====================================================
# WhatsApp — checkout client + lien commande
# =====================================================
# Numéro du shop, format international SANS + ni espaces.
# Au checkout, le client est redirigé vers ce numéro avec son récap commande
# (articles, taille/couleur, prix, total, infos livraison) pré-rempli.
# Ex Côte d'Ivoire : 2250700000000 — Ex France : 33612345678
SHOP_WHATSAPP_PHONE="22500000000"

# =====================================================
# Notifications push admin via ntfy.sh (gratuit, illimité)
# =====================================================
# Setup en 2 minutes (rien à valider, pas de compte) :
#   1. Télécharge l'app "ntfy" sur ton téléphone
#      - Android : https://play.google.com/store/apps/details?id=io.heckel.ntfy
#      - iOS     : https://apps.apple.com/app/ntfy/id1625396347
#   2. Dans l'app, appuie sur "+" pour ajouter un abonnement
#   3. Topic name : choisis une chaîne LONGUE ET UNIQUE
#      Exemple : "tkai-shop-prod-K7m4Qx2nLp"
#      ⚠ Ne mets PAS un mot simple type "tkai" : n'importe qui pourrait
#      s'abonner au même topic et lire tes notifs de commande.
#   4. Server : laisse "https://ntfy.sh" (par défaut)
#   5. Reporte le même topic ci-dessous
NTFY_TOPIC="tkai-shop-CHANGE-ME-WITH-LONG-RANDOM-STRING"

# Optionnel : self-host ntfy ou serveur alternatif
# NTFY_SERVER="https://ntfy.sh"

# =====================================================
# Cloudinary — stockage des images en ligne (gratuit, persistant)
# =====================================================
# Sans Cloudinary, les uploads vont dans /public/uploads (perdu si tu redéploys
# sur Vercel ou si tu changes de serveur). Cloudinary = 25 GB gratuit + CDN.
#
# Setup en 3 min :
#   1. Crée un compte gratuit : https://cloudinary.com (pas de carte demandée)
#   2. Dashboard → Product Environment Credentials
#   3. Copie les 3 valeurs ici (Cloud Name, API Key, API Secret)
#   4. Si tu laisses VIDE, le système retombe sur le stockage local.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
